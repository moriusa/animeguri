{
  "name": "cdk",
  "version": "0.1.0",
  "bin": {
    "cdk": "bin/cdk.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "deploy:dev": "cross-env APP_ENV=dev npx cdk deploy AnimeguriStack*",
    "deploy:prod": "cross-env APP_ENV=prod npx cdk deploy AnimeguriStack*",
    "destroy:dev": "cross-env APP_ENV=dev npx cdk destroy --all",
    "destroy:prod": "cross-env APP_ENV=prod npx cdk destroy --all"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "aws-cdk": "^2.1125.0",
    "cross-env": "^10.1.0",
    "esbuild": "^0.28.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "~6.0.3"
  },
  "dependencies": {
    "@aws-cdk/aws-apigatewayv2-authorizers-alpha": "^2.114.1-alpha.0",
    "@aws-cdk/aws-apigatewayv2-integrations-alpha": "^2.114.1-alpha.0",
    "@aws-cdk/aws-lambda-nodejs": "^1.36.1",
    "@aws-cdk/cloud-assembly-schema": "^54.2.0",
    "@aws-sdk/client-location": "^3.1057.0",
    "@aws-sdk/client-s3": "^3.1057.0",
    "@aws-sdk/client-ssm": "^3.1057.0",
    "@aws-sdk/s3-request-presigner": "^3.1057.0",
    "@supabase/supabase-js": "^2.106.2",
    "aws-cdk-lib": "^2.257.0",
    "aws-lambda": "^1.0.6",
    "constructs": "^10.6.0",
    "dotenv": "^17.4.2",
    "sharp": "^0.35.1"
  },
  "optionalDependencies": {
    "@img/sharp-linux-arm64": "^0.33.0"
  }
}
